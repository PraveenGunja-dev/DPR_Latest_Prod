# ===================================
# Adani Flow - Environment Variables
# ===================================
# Copy this file to .env and fill in your values

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:3002

# Oracle P6 Configuration
# Get your auth token from Oracle P6 Cloud
ORACLE_P6_AUTH_TOKEN=your_p6_auth_token_here
ORACLE_P6_BASE_URL=https://your-instance.p6.oraclecloud.com/your-tenant/p6ws/restapi

# Server Configuration
PORT=3315
NODE_ENV=development

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=adani_flow
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# JWT Configuration
# Generate secure random strings for production
JWT_SECRET=generate_a_secure_random_string_here
REFRESH_TOKEN_SECRET=generate_another_secure_random_string_here

# Email Configuration (Optional - for notifications)
# EMAIL_HOST=smtp.your-email-provider.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-email@domain.com
# EMAIL_PASS=your-email-password
# EMAIL_FROM=noreply@adaniflow.com
